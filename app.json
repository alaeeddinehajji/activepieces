{
  "name": "Activepieces",
  "description": "Open-source workflow automation tool",
  "repository": "https://github.com/activepieces/activepieces",
  "stack": "container",
  "addons": [
    "heroku-postgresql:mini",
    "heroku-redis:mini"
  ],
  "env": {
    "AP_EXECUTION_MODE": {
      "description": "Execution mode for Heroku",
      "value": "SANDBOX_CODE_ONLY",
      "required": true
    },
    "AP_ENCRYPTION_KEY": {
      "description": "32-character encryption key",
      "generator": "secret",
      "required": true
    },
    "AP_FRONTEND_URL": {
      "description": "Your Heroku app URL e.g. https://your-app-name.herokuapp.com",
      "required": true
    },
    "AP_TELEMETRY_ENABLED": {
      "value": "false",
      "required": false
    },
    "AP_POSTGRES_HOST": {
      "description": "PostgreSQL host from DATABASE_URL",
      "required": true
    },
    "AP_POSTGRES_PORT": {
      "value": "5432",
      "required": true
    },
    "AP_POSTGRES_DATABASE": {
      "description": "PostgreSQL database name from DATABASE_URL",
      "required": true
    },
    "AP_POSTGRES_USERNAME": {
      "description": "PostgreSQL username from DATABASE_URL",
      "required": true
    },
    "AP_POSTGRES_PASSWORD": {
      "description": "PostgreSQL password from DATABASE_URL",
      "required": true
    },
    "AP_REDIS_URL": {
      "description": "Redis URL - copy the value from REDIS_URL after deploy",
      "required": true
    }
  }
}
